APP_NAME=Reachlytics API
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://reachlytics:reachlytics@postgres:5432/reachlytics
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=100
ALLOWED_VIDEO_EXTENSIONS=.mp4,.mov,.webm,.mkv
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI providers:
# - openrouter: recommended demo path; uses OpenRouter's OpenAI-compatible chat API.
# - gemini: Google AI Studio path.
# - anthropic: uses Anthropic for reasoning/vision and OpenAI Whisper for transcription.
# - mock: fully offline deterministic fallback; no API keys required.
AI_PROVIDER=mock
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
